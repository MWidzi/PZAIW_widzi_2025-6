<%- include("header.ejs") %>

    <% if (users && users.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <% if (user.role != "admin") { %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.username %></td>
                            <td><%= user.role %></td>
                            <td>
                                <a href="/diffs/<%= user.id %>">View Data</a>
                            </td>
                        </tr>
                    <% } %>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No users found.</p>
    <% } %>

<%- include("footer.ejs") %>

<%- include("header.ejs") %>

<%- include("display_song.ejs") %>

<% if (user && user.role === "admin") { %>
    <div class="admin-actions">
        <a href="/songs/edit/<%= song.key %>" class="button">Edit Song</a>
        <form action="/songs/delete/<%= song.key %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this song?');">
            <button type="submit" class="button delete-button">Delete Song</button>
        </form>
    </div>
<% } %>

<%- include("footer.ejs") %>
